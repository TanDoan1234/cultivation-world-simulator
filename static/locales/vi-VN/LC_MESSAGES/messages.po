# Action: Assassinate
msgid "assassinate_action_name"
msgstr "Thích Sát"

msgid "assassinate_description"
msgstr "Thích sát đối thủ. Nếu ám toán không thành, liền chuyển thành giao chiến trực diện."

msgid "assassinate_requirements"
msgstr "Vô điều kiện hạn chế; yêu cầu thời gian dưỡng chiêu."

msgid "assassinate_story_prompt_success"
msgstr "ám sát_câu chuyện_thành công"
"This is about a successful assassination. No need to describe the combat "
"process, focus on how the assassin lurked, approached, and delivered the "
"fatal, silent strike. The target didn't even have time to react before "
"perishing."

msgid "assassinate_story_prompt_fail"
msgstr "ám sát_câu chuyện_thất bại"
"This is about a failed assassination. The assassin attempted to kill the "
"target, but was keenly detected. Both sides then erupted into fierce direct "
"confrontation. Do not mention specific HP values."

msgid "{avatar} lurks in the shadows, attempting to assassinate {target}..."
msgstr "{avatar} ẩn mình nơi u ám, âm mưu ám sát {target}..."

msgid "{avatar} assassinated successfully! {target} fell without any defense."
msgstr "{avatar} đã ám sát thành công! {target} gục ngã không chút phòng bị."
"{avatar} assassinated successfully! {target} fell without any defense."

msgid "Assassination failed! Both sides engaged in fierce battle."
msgstr "Ám sát thất bại! Song phương giao chiến ác liệt."

# Action: Attack
msgid "attack_action_name"
msgstr "Khai Chiến"

msgid "attack_description"
msgstr "Tấn công đối thủ, lập tức giao chiến."

msgid "attack_requirements"
msgstr "Vô điều kiện."

msgid "attack_story_prompt"
msgstr "tấn công_câu chuyện_mở đầu"
"Do not mention specific HP, damage points, or any numerical expressions. The"
" battle should reflect both sides' techniques, cultivation realms, "
"equipment, etc."

msgid "Missing target parameter"
msgstr "Thiếu mục tiêu chỉ định."

msgid "Target does not exist"
msgstr "Mục tiêu không tồn tại."

msgid "Target is already dead"
msgstr "Mục tiêu đã vẫn lạc."

msgid ""
"{attacker} initiates battle against {target} (Power: {attacker} {att_power} "
"vs {target} {def_power})"
msgstr ""
"{attacker} initiates battle against {target} (Power: {attacker} {att_power} "
"vs {target} {def_power})"

# Action: Breakthrough
msgid "breakthrough_action_name"
msgstr "Đột Phá"

msgid "breakthrough_description"
msgstr "Diễn giải Đột phá"
"Attempt to breakthrough realm (success increases max lifespan, failure "
"reduces it; higher realm, lower success rate)"

msgid "breakthrough_requirements"
msgstr "Người thi triển phải đạt tới bình cảnh; không thể liên tục thi triển."

msgid "Not at bottleneck, cannot breakthrough"
msgstr "Chưa tới bình cảnh, không thể đột phá."

msgid "{avatar} begins attempting breakthrough"
msgstr "{avatar} bắt đầu xung kích đột phá."

msgid "Breakthrough succeeded"
msgstr "Đột phá thành công."

msgid "Breakthrough failed"
msgstr "Đột phá thất bại."

msgid "{avatar} breakthrough result: {result}"
msgstr "{avatar} kết quả đột phá: {result}"

msgid "succeeded"
msgstr "thành công"

msgid "failed"
msgstr "thất bại"

msgid "{avatar} encountered {calamity} tribulation, breakthrough {result}"
msgstr "{avatar} tao ngộ {calamity} thiên kiếp, đột phá {result}"

# Action: Respire
msgid "respire_action_name"
msgstr "Điều Tức"

msgid "respire_description"
msgstr "Diễn giải Điều tức"
"Conform to the Heavenly Dao and respire Qi. The higher the spiritual energy density, the better the effect."

msgid "respire_requirements"
msgstr "Yêu cầu là Đạo môn chính tông hoặc Tán tu."

msgid "Your orthodoxy does not support Qi Respiration."
msgstr "Công pháp của ngươi không tương thích với Thổ nạp linh khí."

msgid "This cave dwelling has been occupied by {name}, cannot respire"
msgstr "Động phủ này đã bị {name} chiếm giữ, không thể Thổ nạp."

msgid "{avatar} begins respiring at {location}, {efficiency}"
msgstr "{avatar} tiến hành Thổ nạp tại {location}, đạt hiệu quả {efficiency}."

msgid "Cultivation has reached bottleneck, cannot continue cultivating"
msgstr "Tu vi đã chạm bình cảnh, không thể tiếp tục tu luyện."

msgid "excellent progress"
msgstr "Tiến triển vượt bậc."

msgid "slow progress (essence mismatch)"
msgstr "Tiến triển chậm chạp (nguyên khí bất hòa)."

msgid "slow progress (sparse essence)"
msgstr "Tiến triển chậm chạp (Linh khí thưa thớt)."

msgid "action_respire_short_name"
msgstr "Điều Tức"

# Action: Escape
msgid "escape_action_name"
msgstr "Đào Thoát"

msgid "escape_description"
msgstr "Thoát ly khỏi truy đuổi của đối thủ (tỷ lệ thành công tùy thuộc vào cơ duyên)."

msgid "escape_requirements"
msgstr "Vô điều kiện."

msgid "{avatar} attempted to escape from {target}: {result}"
msgstr "{avatar} mưu đồ tẩu thoát khỏi {target}: {result}."

msgid "{avatar} attempts to escape from {target}"
msgstr "{avatar} đang mưu đồ tẩu thoát khỏi {target}."

# Action: SelfHeal
msgid "self_heal_action_name"
msgstr "Tự Liệu"

msgid "self_heal_description"
msgstr "Mô tả Tự Phục Hồi."
"Heal injuries through meditation; can fully recover at sect headquarters"

msgid "self_heal_requirements"
msgstr "Khí huyết chưa viên mãn"

msgid "Missing HP information"
msgstr "Sinh lực tin tức khiếm khuyết."

msgid "Current HP is full"
msgstr "Đương kim Sinh lực viên mãn."

msgid "wilderness"
msgstr "Man hoang chi địa."

msgid "{avatar} begins resting and healing at {location}"
msgstr "{avatar} tại {location} khởi đả tọa điều tức."

msgid "{avatar} healing completed (recovered {amount} HP, current HP {hp})"
msgstr "{avatar} dưỡng thương viên mãn (phục hồi {amount} Sinh lực, đương kim Sinh lực {hp})."

# Action: Buy
msgid "buy_action_name"
msgstr "Thỉnh vật"

msgid "buy_description"
msgstr "Tại thành đô, thỉnh mua Pháp Khí, Bảo Vật, hoặc Linh Đan Diệu Dược"

msgid "buy_requirements"
msgstr "Đang tại thành đô, kim tệ dư dả"

msgid "Can only execute in city areas"
msgstr "Chỉ khả tại thành trì chi địa thi triển."

msgid "Unknown item: {name}"
msgstr "Vô danh chi vật: {name}."

msgid "{region} does not sell {item}"
msgstr "{region} bất xuất thụ {item}."

msgid "This area has no shop"
msgstr "Nơi đây vô thương điếm."

msgid "bought"
msgstr "Đã thu mua."

msgid "bought and consumed"
msgstr "Đã thỉnh mua và hấp thụ"

msgid "bought and equipped"
msgstr "Đã thỉnh mua và trang bị"

msgid " (and sold old {item} at reduced price)"
msgstr " (và đã bán đi {item} cũ với giá hạ thấp)"

msgid "{avatar} spent {price} spirit stones in town, {action} {item}{suffix}"
msgstr "{avatar} đã tiêu tốn {price} linh thạch tại trấn nhỏ, {action} {item}{suffix}"

# Action: Sell
msgid "sell_action_name"
msgstr "Xuất thủ"

msgid "sell_description"
msgstr "Mô tả_bán"
"Sell all possessed items of a certain type, or current equipment in town"

msgid "sell_requirements"
msgstr "Đang tại thành đô, và cất giữ vật phẩm/pháp khí có thể xuất thủ"

msgid "Do not possess item/equipment: {name}"
msgstr "Chưa sở hữu vật phẩm/trang bị: {name}"

msgid "Do not possess material: {name}"
msgstr "Chưa sở hữu linh liệu: {name}"

msgid "Do not possess equipment: {name}"
msgstr "Chưa sở hữu trang bị: {name}"

msgid "Cannot sell this type: {name}"
msgstr "Không thể rao bán loại này: {name}"

msgid "{avatar} sold {item} in town"
msgstr "{avatar} đã rao bán {item} tại trấn nhỏ"

# Action: Harvest
msgid "harvest_action_name"
msgstr "Thu hoạch"

msgid "harvest_description"
msgstr "Thu hoạch Linh Thảo tại khu vực này để đắc được Dược Liệu"

msgid "harvest_requirements"
msgstr "Yếu Quyết Thu Thập"
"In normal area with plants, and avatar's realm must be greater than or equal"
" to plant's realm"

msgid "{avatar} begins harvesting at {location}"
msgstr "{avatar} khai thủy thu thập tại {location}"

msgid "{avatar} finished harvesting, obtained: {materials}"
msgstr "{avatar} hoàn thành thu thập, đắc được: {materials}"

# Action: Mine
msgid "mine_action_name"
msgstr "Khai thác"

msgid "mine_description"
msgstr "Khai thác Khoáng Mạch tại khu vực này để đắc được Khoáng Vật"

msgid "mine_requirements"
msgstr "Yếu Quyết Khai Khoáng"
"In normal area with ore veins, and avatar's realm must be greater than or "
"equal to vein's realm"

msgid "{avatar} begins mining at {location}"
msgstr "{avatar} khai thủy khai khoáng tại {location}"

msgid "{avatar} finished mining, obtained: {materials}"
msgstr "{avatar} hoàn thành khai khoáng, đắc được: {materials}"

# Action: Hunt
msgid "hunt_action_name"
msgstr "Liệp sát"

msgid "hunt_description"
msgstr "Liệp sát Yêu Thú tại khu vực này để đắc được Yêu Thú Tài"

msgid "hunt_requirements"
msgstr "Yếu Quyết Liệp Sát"
"In normal area with animals, and avatar's realm must be greater than or "
"equal to animal's realm"

msgid "{avatar} begins hunting at {location}"
msgstr "{avatar} khai thủy liệp sát tại {location}"

msgid "{avatar} finished hunting, obtained: {materials}"
msgstr "{avatar} hoàn thành liệp sát, đắc được: {materials}"

# Action: Refine
msgid "refine_action_name"
msgstr "Luyện chế Linh Đan"

msgid "refine_description"
msgstr "Mô Tả Luyện Hóa"
"Consume materials to attempt refining elixirs (target_realm: QI_REFINEMENT, "
"FOUNDATION_ESTABLISHMENT, CORE_FORMATION, NASCENT_SOUL)"

msgid "refine_requirements"
msgstr "Sở hữu ba loại nguyên liệu cùng phẩm cấp"

msgid "Target realm not specified"
msgstr "Vị diện mục tiêu chưa xác định."

msgid "Invalid realm: {realm}"
msgstr "Vị diện {realm} không hợp lệ."

msgid ""
"Insufficient materials, need {cost} {realm}-tier materials, currently have "
"{count}"
msgstr ""
"Insufficient materials, need {cost} {realm}-tier materials, currently have "
"{count}"

msgid "{avatar} begins attempting to refine {realm}-tier elixir"
msgstr "{avatar} bắt đầu tiến hành luyện chế đan dược phẩm giai {realm}."

msgid ""
"{avatar} failed to refine {realm}-tier elixir, all materials turned to ash"
msgstr ""
"{avatar} failed to refine {realm}-tier elixir, all materials turned to ash"

msgid "Refining succeeded! Obtained {realm} elixir '{item}'"
msgstr "Luyện chế thành công! Thu được đan dược phẩm giai {realm} '{item}'."

msgid "{avatar} successfully refined {realm}-tier elixir '{item}'"
msgstr "{avatar} thành công ngưng luyện đan dược phẩm giai {realm} '{item}'."

# Action: Cast
msgid "cast_action_name"
msgstr "Thi triển Pháp Bảo"

msgid "cast_description"
msgstr "mô_tả_ngưng_đúc"
"Consume materials to attempt casting treasures (target_realm: QI_REFINEMENT,"
" FOUNDATION_ESTABLISHMENT, CORE_FORMATION, NASCENT_SOUL)"

msgid "cast_requirements"
msgstr "Sở hữu đủ năm linh tài cùng cảnh giới"

msgid "{avatar} begins attempting to cast {realm}-tier treasure"
msgstr "{avatar} bắt đầu tiến hành ngưng đúc pháp bảo phẩm giai {realm}."

msgid ""
"{avatar} failed to cast {realm}-tier treasure, all materials turned to ash"
msgstr ""
"{avatar} failed to cast {realm}-tier treasure, all materials turned to ash"

msgid "Casting succeeded! Obtained {realm} {label} '{item}'"
msgstr "Ngưng đúc thành công! Thu được {label} phẩm giai {realm} '{item}'."

msgid "{avatar} successfully cast {realm}-tier {label} '{item}'"
msgstr "{avatar} thành công ngưng đúc {label} phẩm giai {realm} '{item}'."

# Action: HelpPeople
msgid "help_people_action_name"
msgstr "Hành thiện giúp người"

msgid "help_people_description"
msgstr "Trợ giúp dân chúng trong trấn, tiêu tốn chút linh thạch"

msgid "help_people_requirements"
msgstr "Chỉ thi hành tại khu vực thành trấn, và yêu cầu đủ linh thạch"

msgid "Only righteous alignment can execute"
msgstr "Chỉ chính đạo mới có thể thi hành."

msgid "Insufficient spirit stones"
msgstr "Linh thạch bất túc"

msgid "{avatar} begins helping people in town"
msgstr "{avatar} bắt đầu hành thiện trợ giúp dân chúng trong trấn"

# Action: PlunderPeople
msgid "plunder_people_action_name"
msgstr "Cướp đoạt tài vật"

msgid "plunder_people_description"
msgstr "Cướp đoạt tài vật từ dân chúng trong trấn, thu về chút linh thạch"

msgid "plunder_people_requirements"
msgstr "Chỉ thi hành tại khu vực thành trấn, và phẩm tính nhân vật phải là 'tà ác'"

msgid "Only evil alignment can execute"
msgstr "Duy ma tu phương có thể thi triển"

msgid "{avatar} begins plundering people in town"
msgstr "{avatar} bắt đầu cướp đoạt chúng sinh phàm tục trong trấn"

# Action: DevourPeople
msgid "devour_people_action_name"
msgstr "Thôn phệ chúng sinh"

msgid "devour_people_description"
msgstr "Thôn phệ chúng sinh, tăng phúc chiến lực vượt bậc"

msgid "devour_people_requirements"
msgstr "Sở hữu Vạn Hồn Phiên"

msgid ""
"Forbidden illegal action (missing Ten Thousand Souls Banner or permission)"
msgstr ""
"Forbidden illegal action (missing Ten Thousand Souls Banner or permission)"

msgid "{avatar} begins devouring people in town"
msgstr "{avatar} bắt đầu thôn phệ sinh linh phàm tục trong trấn"

# Action: Play
msgid "play_action_name"
msgstr "Hưu nhàn tiêu dao"

msgid "play_description"
msgstr "Hoạt động hưu nhàn, thư giãn thả lỏng thân tâm"

msgid "play_requirements"
msgstr "Mục tiêu trong tầm tương tác"

msgid "{avatar} begins leisure activities"
msgstr "{avatar} bắt đầu tiêu khiển"

# Action: NurtureWeapon
msgid "nurture_weapon_action_name"
msgstr "Bồi dưỡng Pháp bảo"

msgid "nurture_weapon_description"
msgstr "Bồi dưỡng thần binh, tăng cường binh khí tạo nghệ."

msgid "nurture_weapon_requirements"
msgstr "Vô cấm kỵ."

msgid ""
"{avatar} nurturing {old_weapon}, the weapon's spirituality greatly "
"increased, evolved into {new_weapon}!"
msgstr ""
"{avatar} nurturing {old_weapon}, the weapon's spirituality greatly "
"increased, evolved into {new_weapon}!"

msgid "{avatar} begins nurturing {weapon}"
msgstr "{avatar} bắt đầu ôn dưỡng {weapon}"

msgid ""
"{avatar} finished nurturing {weapon}, proficiency increased to "
"{proficiency}%"
msgstr ""
"{avatar} finished nurturing {weapon}, proficiency increased to "
"{proficiency}%"

# Action: Catch
msgid "catch_action_name"
msgstr "Thuần hóa yêu thú."

msgid "catch_description"
msgstr "Miêu tả việc bắt giữ"
"Attempt to tame a spirit beast to become your own. Can only have one spirit "
"beast, but can replace lower grade with higher grade"

msgid "catch_requirements"
msgstr "Điều kiện bắt giữ"
"Only Hundred Beasts Sect; in normal area with animals; target animal realm "
"not higher than character"

msgid "Not currently in normal area"
msgstr "Không ở chốn phàm tục"

msgid "Current area {region} has no animals"
msgstr "Khu vực {region} hiện tại không có phàm thú"

msgid "Animal realms in current area exceed character realm"
msgstr "Cảnh giới linh thú tại phương vực hiện tại đã vượt quá tu vi cảnh giới của bản thân."

msgid "{avatar} attempts to tame spirit beast at {location}"
msgstr "{avatar} nếm thử thu phục linh thú tại {location}"

msgid "{avatar} failed to tame spirit beast"
msgstr "{avatar} thu phục linh thú bất thành"

msgid ""
"{avatar} successfully tamed spirit beast, {realm} realm {beast} became their"
" spirit beast"
msgstr ""
"{avatar} successfully tamed spirit beast, {realm} realm {beast} became their"
" spirit beast"

