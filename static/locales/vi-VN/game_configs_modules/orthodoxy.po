# Dao (Daoism)
msgid "ORTHODOXY_DAO_NAME"
msgstr "Đạo"

msgid "ORTHODOXY_DAO_DESC"
msgstr "Thuận theo Thiên Đạo, hấp nạp linh khí, nâng cao cảnh giới tu luyện."

# Buddhism
msgid "ORTHODOXY_BUDDHISM_NAME"
msgstr "Phật Môn"

msgid "ORTHODOXY_BUDDHISM_DESC"
msgstr "Phổ độ chúng sinh, nâng cao cảnh giới tu luyện thông qua thiền định và đốn ngộ."

# Confucianism
msgid "ORTHODOXY_CONFUCIANISM_NAME"
msgstr "Nho Giáo"

msgid "ORTHODOXY_CONFUCIANISM_DESC"
msgstr "Giáo hóa bách tính, bồi dưỡng Hạo Nhiên Chính Khí, cảnh giới tự nhiên tăng trưởng."

# Nature (Sanxiu)
msgid "ORTHODOXY_SANXIU_NAME"
msgstr "Thiên Địa Tự Nhiên"

msgid "ORTHODOXY_SANXIU_DESC"
msgstr "Lấy Thiên Địa làm sư, thuận theo Đạo Tự Nhiên."

msgid "Orthodoxy [{name}]"
msgstr "Chính Thống [{name}]"

# Martial (Wu)
msgid "ORTHODOXY_WU_NAME"
msgstr "Võ Đạo"

msgid "ORTHODOXY_WU_DESC"
msgstr "Dĩ võ nhập Đạo, đoán tạo nhục thân. Tuy tiến cảnh chậm chạp, nhưng căn cơ kiên cố, đột phá bình cảnh dễ như trở bàn tay."