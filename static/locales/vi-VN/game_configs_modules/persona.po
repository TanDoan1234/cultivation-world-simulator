msgstr "Tâm nhãn hẹp hòi, chẳng thể chịu đựng kẻ khác vượt lên."

#. persona.csv: 重亲情
msgid "PERSONA_66_NAME"
msgstr "Người trọng tình thân."

#. persona.csv: 你重视家庭和血缘关系，以家族利益为重。...
msgid "PERSONA_66_DESC"
msgstr "HÓA THÂN_66_DIỄN GIẢI"
"You value family and blood relationships, putting family interests first."

#. persona.csv: 重义气
msgid "PERSONA_67_NAME"
msgstr "Chính trực."

#. persona.csv: 你重视朋友义气，为朋友可以两肋插刀。...
msgid "PERSONA_67_DESC"
msgstr "HÓA THÂN_67_DIỄN GIẢI"
"You value friendship and loyalty, willing to go to great lengths for your "
"friends."

#. persona.csv: 孤身一人
msgid "PERSONA_68_NAME"
msgstr "Độc lai độc vãng."

#. persona.csv: 你习惯独来独往，不轻易与人深交。...
msgid "PERSONA_68_DESC"
msgstr "HÓA THÂN_68_DIỄN GIẢI"
"You are accustomed to being alone, not easily forming deep connections with "
"others."

#. persona.csv: 专情
msgid "PERSONA_69_NAME"
msgstr "Tận tâm."

#. persona.csv: 你对爱情专一，一旦认定便不会改变。...
msgid "PERSONA_69_DESC"
msgstr "Khi đã vướng vào lưới tình, ngươi một lòng tận hiến, lời thề son sắt chẳng đổi dời."

#. persona.csv: 多情
msgid "PERSONA_70_NAME"
msgstr "Lãng mạn."

#. persona.csv: 你容易动情，对美好的感情充满向往。...
msgid "PERSONA_70_DESC"
msgstr "HÓA THÂN_70_DIỄN GIẢI"
"You are easily moved by emotions, full of longing for beautiful feelings."

#. persona.csv: 薄情
msgid "PERSONA_71_NAME"
msgstr "Lạnh lùng vô cảm."

#. persona.csv: 你对感情淡漠，不会轻易动心。...
msgid "PERSONA_71_DESC"
msgstr "Ngươi đối với ái tình hờ hững, tâm như băng đá, khó lay chuyển."

#. persona.csv: 贪玩
msgid "PERSONA_1001_NAME"
msgstr "Hoạt bát tinh nghịch."

#. persona.csv: 沉迷玩乐，不思进取。...
msgid "PERSONA_1001_DESC"
msgstr "Chỉ lo vui thú trần gian, chẳng màng đến việc tu thân."

#. persona.csv: 书痴
msgid "PERSONA_1002_NAME"
msgstr "Người say mê thư tịch."

#. persona.csv: 嗜书如命。...
msgid "PERSONA_1002_DESC"
msgstr "Chìm đắm trong thư quyển."

#. persona.csv: 茶痴
msgid "PERSONA_1003_NAME"
msgstr "Ái Trà Nhân"

#. persona.csv: 宁可三日无食，不可一日无茶。...
msgid "PERSONA_1003_DESC"
msgstr "Thiếu trà, nhất nhật nan an"

#. persona.csv: 琴师
msgid "PERSONA_1004_NAME"
msgstr "Cầm Sĩ"

#. persona.csv: 善抚琴。...
msgid "PERSONA_1004_DESC"
msgstr "Cầm kỹ tinh thông"

#. persona.csv: 游历者
msgid "PERSONA_1005_NAME"
msgstr "Lãng Khách"

#. persona.csv: 读万卷书不如行万里路。...
msgid "PERSONA_1005_DESC"
msgstr "HÓA THÂN_1005_DIỄN GIẢI"
"Reading ten thousand books is not as good as traveling ten thousand miles."

#. persona.csv: 棋痴
msgid "PERSONA_1006_NAME"
msgstr "Kỳ Sĩ"

#. persona.csv: 善弈者长生。...
msgid "PERSONA_1006_DESC"
msgstr "Kỳ nghệ tinh thâm, thọ nguyên miên trường"
