msgid "WEAPON_1051_DESC"
msgstr "Một bộ phi kiếm luyện chế từ Thiên Lôi Trúc, ẩn chứa Trấn Tà Thần Lôi, dùng để trấn áp vạn tà trong thiên hạ."

#. weapon.csv: 随心铁杆兵
msgid "WEAPON_1052_NAME"
msgstr "Như Ý Thiết Bổng"

#. weapon.csv: 六耳猕猴的兵器，随心变化，大小如意。...
msgid "WEAPON_1052_DESC"
