#
msgid ""
msgstr ""

# MutualAction Base
msgid "mutual_action_name"
msgstr "Song phương hành động"

msgid "mutual_action_requirements"
msgstr "Mục tiêu trong tầm thi triển"

msgid "Cannot initiate interaction with self"
msgstr "Bất khả tự thân khởi sự tương tác."

msgid "{initiator} initiates {action} with {target}"
msgstr "{initiator} phát khởi {action} cùng {target}."

msgid "{target} feedback to {initiator}: {feedback}"
msgstr "{target} hồi đáp đến {initiator}: {feedback}."

# MutualAction: Attack
msgid "mutual_attack_action_name"
msgstr "Công kích"

msgid "mutual_attack_description"
msgstr "Công kích mục tiêu"

msgid "mutual_attack_requirements"
msgstr "Mục tiêu trong tầm thi triển; bất khả liên tục thi triển"

msgid "Target not within interaction range"
msgstr "Đối tượng không ở trong tầm giao thiệp."

# MutualAction: DriveAway
msgid "drive_away_action_name"
msgstr "Khu trục"

msgid "drive_away_description"
msgstr "Dùng uy lực trấn áp, bức bách địch nhân rời khỏi chốn này"

msgid "drive_away_requirements"
msgstr "Mục tiêu trong tầm thi triển; bất khả liên tục thi triển"

msgid "Cannot drive away in wilderness"
msgstr "Bất khả ngự không tại vùng hoang dã."

# MutualAction: Conversation
msgid "conversation_action_name"
msgstr "Đàm luận"

msgid "conversation_description"
msgstr "Cùng người khác đàm đạo"

msgid "conversation_requirements"
msgstr "Mục tiêu trong tầm thi triển"

msgid "{avatar1} conversation with {avatar2}: {content}"
msgstr "{avatar1} đàm thoại cùng {avatar2}: {content}."

# MutualAction: Talk
msgid "talk_action_name"
msgstr "Đàm thoại"

msgid "talk_description"
msgstr "Khởi xướng đàm luận cùng một người khác, bất khả tự thân"

msgid "talk_requirements"
msgstr "Mục tiêu trong tầm thi triển"

msgid "feedback_talk"
msgstr "Đàm thoại"

msgid "{target} accepted {initiator}'s talk invitation"
msgstr "{target} chấp thuận lời mời đàm luận của {initiator}."

msgid "{target} rejected {initiator}'s talk invitation"
msgstr "{target} khước từ lời mời đàm luận của {initiator}."

# MutualAction: Spar
msgid "spar_action_name"
msgstr "Tỷ thí"

msgid "spar_description"
msgstr "mô_tả_tỉ_võ"
"Spar with target, stop at the right moment (greatly increases weapon "
"proficiency, no damage)"

msgid "spar_requirements"
msgstr "Mục tiêu trong tầm ảnh hưởng; không thể liên tục thi triển"

msgid "spar_story_prompt"
msgstr "Cốt truyện luận võ"
"This is a friendly sparring between two people, stopping at the right "
"moment, without real harm. Focus on describing the exquisite moves of both "
"sides and their mutual inspiration. Do not include bloody or severe injury "
"descriptions."

msgid ""
"{winner} gained slight advantage in sparring, defeated {loser}. ({winner} "
"proficiency +{w_gain}, {loser} proficiency +{l_gain})"
msgstr ""
"{winner} gained slight advantage in sparring, defeated {loser}. ({winner} "
"proficiency +{w_gain}, {loser} proficiency +{l_gain})"

msgid "{initiator} challenges {target} to spar"
msgstr "{initiator} khiêu chiến {target} luận võ"

# MutualAction: Gift
msgid "gift_action_name"
msgstr "Ban tặng"

msgid "gift_description"
msgstr "Mô tả lễ vật"
"Gift spirit stones or items to other. Use 'item_id' parameter: Item ID (int)"
" or 'SPIRIT_STONE'."

msgid "gift_requirements"
msgstr "Yêu cầu lễ vật"
"Initiator possesses the item; target within interaction range; elixirs "
"cannot be gifted"

msgid "spirit stones"
msgstr "Linh thạch"

msgid "Item not found: {name}"
msgstr "Không tìm thấy bảo vật: {name}"

msgid "Insufficient spirit stones (current: {current}, need: {need})"
msgstr "Linh thạch bất túc (hiện có: {current}, cần: {need})"

msgid "Item not equipped: {name}"
msgstr "Pháp bảo chưa trang bị: {name}"

msgid "Insufficient item: {name}"
msgstr "Vật phẩm bất túc: {name}"

msgid "Elixirs cannot be gifted"
msgstr "Đan dược không thể hiến tặng"

msgid "Gift you {item}"
msgstr "Tặng ngươi {item}"

msgid "{initiator} attempts to gift {item} to {target}"
msgstr "{initiator} toan tính ban tặng {item} cho {target}"

msgid "{initiator} successfully gifted {item} to {target}"
msgstr "{initiator} đã thành công ban tặng {item} cho {target}"

# MutualAction: Impart
msgid "impart_action_name"
msgstr "Truyền thụ"

msgid "impart_description"
msgstr "Mô tả truyền thụ"
"Impart cultivation experience to your disciple, martial grandchild, martial sibling, child, grandchild, or friend"

msgid "impart_requirements"
msgstr "Yêu cầu truyền thụ"
"Target must be your disciple, martial grandchild, martial sibling, child, grandchild, or friend; initiator level > target level + 20; target "
"within interaction range; cannot execute consecutively"

msgid "Target is not your apprentice"
msgstr "Đối tượng phi đệ tử của ngươi"

msgid "Target is not your disciple, martial grandchild, martial sibling, child, grandchild, or friend"
msgstr "Đối tượng chẳng phải đệ tử, võ tôn, võ huynh đệ, con cái, cháu chắt, hay bằng hữu của ngươi"

msgid ""
"Level difference insufficient, need 20 levels (current gap: {diff} levels)"
msgstr ""
"Level difference insufficient, need 20 levels (current gap: {diff} levels)"

msgid "{giver} imparts cultivation knowledge to {receiver}"
msgstr "{giver} truyền thụ kiến thức tu luyện cho {receiver}"

msgid "{master} imparts cultivation knowledge to apprentice {apprentice}"
msgstr "{master} truyền thụ tu luyện chi đạo cho đệ tử {apprentice}"

# MutualAction: Occupy
msgid "occupy_action_name"
msgstr "Cưỡng chiếm Động phủ"

msgid "occupy_description"
msgstr "Chiếm cứ hoặc đoạt lấy động phủ. Cần lưu ý: Hành động này có thể khơi mào tranh đấu với chủ nhân động phủ"

msgid "occupy_requirements"
msgstr "Mục tiêu trong tầm ảnh hưởng; không thể liên tục thi triển"

msgid "occupy_story_prompt"
msgstr "Lời nhắc cốt truyện chiếm lĩnh"
"This is a battle for cave dwelling. Do not mention specific HP or damage "
"values."

msgid "feedback_yield"
msgstr "Nhượng bộ"

msgid "Cannot find region: {region}"
msgstr "Vô pháp tầm thấy lĩnh địa: {region}"

msgid "{region} is not a cultivation area, cannot occupy"
msgstr "Lĩnh địa {region} phi tu luyện chi địa, vô pháp chiếm cứ"

msgid "Already the owner of this cave dwelling"
msgstr "Đã chính là chủ nhân của động phủ này"

msgid "{initiator} attempts to seize {region} from {host}"
msgstr "{initiator} âm mưu đoạt lấy lĩnh địa {region} từ tay {host}"

msgid "{initiator} forced {target} to yield {region}"
msgstr "{initiator} cưỡng ép {target} nhượng lại lĩnh địa {region}"

msgid ""
"{initiator} attempted to seize {target}'s cave dwelling {region}, {target} "
"rejected and engaged in battle"
msgstr ""
"{initiator} attempted to seize {target}'s cave dwelling {region}, {target} "
"rejected and engaged in battle"

msgid ", successfully seized {region}"
msgstr ", thành công đoạt được lĩnh địa {region}"

msgid ", defended {region}"
msgstr ", thành công thủ hộ lĩnh địa {region}"
