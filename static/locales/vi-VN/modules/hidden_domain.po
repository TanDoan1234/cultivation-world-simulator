msgid "hidden_domain_story_prompt"
msgstr "Dẫn Truyện Bí Cảnh"
"Describe the exploration of the hidden domain. Focus on individual "
"experiences or interactions between multiple people (such as encounters, "
"cooperation, competition, or even attacks). Cover dangers encountered, "
"opportunities gained, or the disappointment of returning empty-handed, "
"creating a mysterious, tense, or unpredictable atmosphere."

msgid "Hidden Domains opened: {names}"
msgstr "{danh tự}"

msgid "Hidden Domain {name} opened! Entry restricted to {realm} only."
msgstr "Bí Cảnh {name} đã khai mở! Chỉ {realm} mới có thể tiến nhập."

msgid "{name} perished in the hidden domain {domain}."
msgstr "{name} đã vẫn lạc trong bí cảnh {domain}."

msgid "{name} found a treasure {loot} in {domain}!"
msgstr "{name} đã thu hoạch được bảo vật {loot} trong {domain}!"

msgid "{names} returned from {domain} empty-handed."
msgstr "{names} đã hồi quy từ {domain} trong tay trắng."

msgid "Perished in a Hidden Domain"
msgstr "Vẫn Lạc Trong Bí Cảnh"

