msgstr "Cần ở trong thành trì mới có thể khai hóa bá tánh."

msgid "{avatar} begins educating people in {city}."
msgstr "{avatar} bắt đầu khai hóa bá tánh tại {city}."

msgid "{avatar} finished educating people. Merit accumulated (+{exp})."
msgstr "{avatar} đã khai hóa xong bá tánh. Công đức tích lũy (+{exp})."

msgid "The prosperity of {city} has increased due to {avatar}'s teachings."
msgstr "Sự phồn thịnh của {thành trì} đã thăng hoa nhờ vào đạo pháp của {avatar}."

