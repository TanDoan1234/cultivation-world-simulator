# Action: Meditate
msgid "meditate_action_name"
msgstr "Đả tọa."

msgid "meditate_description"
msgstr "Mô tả Tọa thiền"
"Buddhist cultivation. Calm the mind through Zen meditation, with a chance of"
" epiphany for massive cultivation gain."

msgid "meditate_requirements"
msgstr "Yêu cầu Phật môn chính tông."

msgid "Your orthodoxy does not support Zen Meditation."
msgstr "Đạo thống của ngươi không chấp thuận Thiền Tông Tọa thiền."

