# Fortune messages
msgid "Encountered fortune ({theme}), {result}"
msgstr "Gặp gỡ kỳ duyên ({theme}), thu được {result}"

msgid "Found weapon '{weapon}', {exchange_result}"
msgstr "Tìm thấy pháp bảo '{weapon}', {exchange_result}"

msgid "Found auxiliary equipment '{auxiliary}', {exchange_result}"
msgstr "Tìm thấy linh khí phụ trợ '{auxiliary}', {exchange_result}"

msgid "Comprehended technique '{technique}', {exchange_result}"
msgstr "Lĩnh ngộ công pháp '{technique}', {exchange_result}"

msgid "{name} obtained {amount} spirit stones"
msgstr "{name} đắc được {amount} linh thạch"

msgid "{name} cultivation increased by {exp} points"
msgstr "Tu vi của {name} tăng thêm {exp} điểm"

msgid "{apprentice} became disciple of {master}"
msgstr "{apprentice} đã trở thành đệ tử của {master}"

# Fortune - discovery intro messages
msgid "You discovered a {realm} weapon '{weapon}' during the fortune."
msgstr "Ngươi đã phát hiện một pháp bảo {realm} cấp '{weapon}' trong kỳ duyên. Nhưng ngươi đã có sẵn '{current_weapon}'."

msgid " But you already have '{current_weapon}'."
msgstr "Song ngươi đã có '{current_weapon}' rồi."

msgid ""
"You discovered a {realm} auxiliary equipment '{auxiliary}' during the "
"fortune."
msgstr ""
"You discovered a {realm} auxiliary equipment '{auxiliary}' during the "
"fortune."

msgid " But you already have '{current_auxiliary}'."
msgstr "Đáng tiếc, ngươi đã nắm giữ '{current_auxiliary}' rồi."

msgid "You comprehended superior technique '{technique}' during the fortune."
msgstr "Ngươi đã lĩnh hội được công pháp thượng thừa '{technique}' trong kỳ ngộ này."

msgid " This conflicts with your current technique '{current_technique}'."
msgstr "Điều này xung khắc với công pháp '{current_technique}' hiện tại của ngươi."

